# Ready-to-paste .env fragment that engages the deep-model images you already pulled.
# Append the lines you want to your real .env (beside docker-compose.yml), then restart the backend.
# The backend must be able to run `docker run` (run it on the host, or mount /var/run/docker.sock).
# With any pair omitted, that tool falls back to its rule-based proxy -- never a faked result.

# --- on-target efficacy (CRISPR) ---
BIOFORGE_DEEPCRISPR_ENABLED=true
BIOFORGE_DEEPCRISPR_DOCKER_IMAGE=bioforge/deepcrispr:legacy
# (weights provenance = the digest-pinned base image michaelchuai/deepcrispr@sha256:812deef..., baked into bioforge/deepcrispr:legacy)

BIOFORGE_AZIMUTH_ENABLED=true
BIOFORGE_AZIMUTH_DOCKER_IMAGE=bioforge/azimuth:legacy

# --- edit-outcome (CRISPR NHEJ) ---
BIOFORGE_LINDEL_ENABLED=true
BIOFORGE_LINDEL_DOCKER_IMAGE=bioforge/lindel:legacy

BIOFORGE_FORECAST_ENABLED=true
BIOFORGE_FORECAST_DOCKER_IMAGE=bioforge/forecast:legacy

# --- variant calling (call_variants tool + GIAB benchmark) ---
BIOFORGE_DEEPVARIANT_ENABLED=true
BIOFORGE_DEEPVARIANT_DOCKER_IMAGE=google/deepvariant:1.6.1
BIOFORGE_DEEPVARIANT_MODEL_TYPE=WGS

# --- MSA (build the image first: docker build -t bioforge/mafft:legacy backend/src/bioforge/tools/sequence/models/mafft/legacy) ---
BIOFORGE_MAFFT_ENABLED=true
BIOFORGE_MAFFT_DOCKER_IMAGE=bioforge/mafft:legacy

# --- benchmark data consent (fetch-on-first-use, never vendored) ---
BIOFORGE_CRISPOR_EFFDATA_CONSENT=true
BIOFORGE_FORECAST_PROFILES_CONSENT=true
