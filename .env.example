# ============================================================================
# BioForge configuration. Copy to `.env` and edit. Everything below the core
# block is OPT-IN: unset = the default single-user / inline / rule-based path,
# which is byte-identical to shipping behavior. See docs/READINESS.md for the
# full "what do I turn on to light up X" checklist.
# ============================================================================

# --- Core (required to run the agent) ---------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
BIOFORGE_DB_URL=sqlite+aiosqlite:///./bioforge.db
BIOFORGE_DEFAULT_MODEL=claude-sonnet-4-6
BIOFORGE_DEFAULT_PROJECT_ID=default-project
BIOFORGE_ENTREZ_EMAIL=you@example.com

# Allowed browser origins (comma-separated). Default = local dev ports. Set to your
# deployed frontend origin before exposing the API publicly. "*" = any (no credentials).
# BIOFORGE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- OpenTelemetry tracing (leave off for quiet local dev) ------------------
BIOFORGE_OTEL_ENABLED=false
BIOFORGE_OTEL_EXPORTER=console
BIOFORGE_OTEL_ENDPOINT=http://localhost:4318/v1/traces
BIOFORGE_OTEL_HEADERS=

# --- Accounts / multi-user (opt-in) -----------------------------------------
# BIOFORGE_AUTH_ENABLED=true
# BIOFORGE_AUTH_ALLOW_REGISTRATION=true

# --- Cost controls (opt-in) -------------------------------------------------
# BIOFORGE_BUDGET_ENABLED=true
# BIOFORGE_MONTHLY_BUDGET_USD=50
# BIOFORGE_RATE_LIMIT_ENABLED=true
# BIOFORGE_RATE_LIMIT_RUNS_PER_HOUR=60

# --- Durable jobs (Celery; needs the compose `workers` profile) -------------
# BIOFORGE_TASK_QUEUE=celery
# BIOFORGE_REDIS_URL=redis://redis:6379/0
# (point the API at the shared Postgres so the worker and API share the run DB)
# BIOFORGE_DB_URL=postgresql+asyncpg://bioforge:bioforge@postgres:5432/bioforge

# --- Object storage (opt-in; needs the compose `storage` profile) -----------
# BIOFORGE_STORAGE_BACKEND=minio
# BIOFORGE_MINIO_ENDPOINT=minio:9000
# BIOFORGE_MINIO_ACCESS_KEY=bioforge
# BIOFORGE_MINIO_SECRET_KEY=bioforge-dev
# BIOFORGE_MINIO_BUCKET=bioforge

# ============================================================================
# DEEP MODELS (out-of-process Docker images). Build/pull the image, then set
# BOTH the *_ENABLED flag AND the *_DOCKER_IMAGE name. With the flag off the
# tool degrades to its deterministic rule-based proxy (never a faked result).
# The backend must be able to run `docker run` (host install, or mount the
# Docker socket into the backend container).
# ============================================================================

# DeepCRISPR — deep on-target efficacy (Apache-2.0). Image ~7.8 GB.
# BIOFORGE_DEEPCRISPR_ENABLED=true
# BIOFORGE_DEEPCRISPR_DOCKER_IMAGE=bioforge/deepcrispr:legacy

# Azimuth / Doench Rule Set 2 — secondary on-target scorer (BSD-3-Clause).
# BIOFORGE_AZIMUTH_ENABLED=true
# BIOFORGE_AZIMUTH_DOCKER_IMAGE=bioforge/azimuth:legacy

# Lindel — per-guide edit-outcome (MIT).
# BIOFORGE_LINDEL_ENABLED=true
# BIOFORGE_LINDEL_DOCKER_IMAGE=bioforge/lindel:legacy

# FORECasT — per-guide edit-outcome (MIT). Built FROM quay.io/felicityallen/selftarget.
# BIOFORGE_FORECAST_ENABLED=true
# BIOFORGE_FORECAST_DOCKER_IMAGE=bioforge/forecast:legacy

# MAFFT — multiple-sequence alignment (core MAFFT is BSD-3-Clause; image must be
# core-only — see backend/.../models/mafft/legacy/Dockerfile). Or a local `mafft` binary.
# BIOFORGE_MAFFT_ENABLED=true
# BIOFORGE_MAFFT_DOCKER_IMAGE=bioforge/mafft:legacy

# DeepVariant — variant caller for the GIAB benchmark + the call_variants tool (BSD-3-Clause).
# BIOFORGE_DEEPVARIANT_ENABLED=true
# BIOFORGE_DEEPVARIANT_DOCKER_IMAGE=google/deepvariant:1.6.1
# BIOFORGE_DEEPVARIANT_MODEL_TYPE=WGS

# inDelphi — edit-outcome distributions (NON-COMMERCIAL license; weights fetched on first use).
# BIOFORGE_INDELPHI_CONSENT_NONCOMMERCIAL=true
# BIOFORGE_INDELPHI_DATA_DIR=

# ============================================================================
# BENCHMARK DATA (only needed to turn §13 benchmarks from guard_only -> live).
# Most are fetched-on-first-use behind a consent flag; GIAB needs staged files.
# ============================================================================

# crisporPaper guide-efficiency data (UNLICENSED -> fetched, never vendored).
# BIOFORGE_CRISPOR_EFFDATA_CONSENT=true
# FORECasT processed profiles (CC BY 4.0).
# BIOFORGE_FORECAST_PROFILES_CONSENT=true

# GIAB live variant-calling benchmark inputs (you stage these; reference BUILD must be stated).
# BIOFORGE_GIAB_REFERENCE_PATH=/data/giab/GRCh38.fa
# BIOFORGE_GIAB_REFERENCE_BUILD=GRCh38.p14
# BIOFORGE_GIAB_READS_PATH=/data/giab/HG002.bam
# BIOFORGE_GIAB_TRUTH_VCF_PATH=/data/giab/HG002_truth.vcf.gz
# BIOFORGE_GIAB_CONFIDENT_BED_PATH=/data/giab/HG002_confident.bed
# BIOFORGE_GIAB_REGIONS=chr20

# ============================================================================
# CLOUD-GPU execution path (Limitation #3). "none" = GPU work refuses honestly.
# ============================================================================
# BIOFORGE_GPU_BACKEND=http
# BIOFORGE_GPU_ENDPOINT=https://your-gpu-service.example.com
# BIOFORGE_GPU_API_KEY=

# ============================================================================
# Pipelines (Limitation #5). Needs the `nextflow` binary on PATH (a JVM tool,
# NOT a Docker image) in addition to Docker for the pipeline containers.
# ============================================================================
# BIOFORGE_NEXTFLOW_ENABLED=true
