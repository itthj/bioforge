ANTHROPIC_API_KEY=sk-ant-...
BIOFORGE_DB_URL=sqlite+aiosqlite:///./bioforge.db
BIOFORGE_DEFAULT_MODEL=claude-sonnet-4-6
BIOFORGE_DEFAULT_PROJECT_ID=default-project
BIOFORGE_ENTREZ_EMAIL=you@example.com

# OpenTelemetry tracing. Leave disabled for quiet local dev.
BIOFORGE_OTEL_ENABLED=false
BIOFORGE_OTEL_EXPORTER=console
BIOFORGE_OTEL_ENDPOINT=http://localhost:4318/v1/traces
BIOFORGE_OTEL_HEADERS=
